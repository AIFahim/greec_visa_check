SUPERSAAS_URL=https://www.supersaas.com/schedule/login/GreekEmbassyInDublin/Visas
SUPERSAAS_EMAIL=your-supersaas-login@example.com
SUPERSAAS_PASSWORD=your-supersaas-password

# Email notifications (optional if you use Telegram)
GMAIL_ADDRESS=sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_TO=recipient@example.com

# Telegram notifications (optional — faster than email; configure via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Auto-booking: if true, when a slot is detected the script fills the pre-populated
# reservation form and clicks "Create reservation" automatically.
AUTO_BOOK=false
# Optional: don't auto-book slots on or after this ISO date (YYYY-MM-DD).
AUTO_BOOK_CUTOFF_DATE=

# Values used to fill any custom "purpose of trip" / "host" fields on the
# booking form if the embassy adds them later. Defaults assume the user's
# research visit to CERTH.
BOOKING_PURPOSE=Research visit to CERTH, Thessaloniki, Greece
BOOKING_HOST=CERTH (Centre for Research & Technology Hellas), Thessaloniki

CHECK_INTERVAL_SECONDS=60
HEADLESS=true
DEBUG_DUMP=false
